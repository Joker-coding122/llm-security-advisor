# ============================================================
# 把这个文件复制为 .env，然后填入你的真实 API key
# .env 文件不会被 git 提交（已在 .gitignore 中）
# ============================================================

# DeepSeek API（推荐，便宜）
API_KEY=sk-your-deepseek-api-key-here
BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat

# 如果你用 OpenAI 官方 API，改成：
# API_KEY=sk-your-openai-api-key-here
# BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o-mini

# ============================================================
# 阶段 6：调用侧速率限制（可选，留空使用默认值）
# RATE_LIMIT_MAX     —— 单会话窗口内最大请求次数，默认 20
# RATE_LIMIT_WINDOW  —— 滑动窗口大小（秒），默认 60
# ============================================================
# RATE_LIMIT_MAX=20
# RATE_LIMIT_WINDOW=60

# ============================================================
# 阶段 7：演示模式（公开部署用）
# DEMO_MODE=true 时不调真 LLM，返回模拟回复，零 token 消耗。
# 未配置 API_KEY 或仍为占位符时也会自动进入演示模式。
# ============================================================
# DEMO_MODE=true
